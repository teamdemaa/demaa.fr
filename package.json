{
  "name": "demaa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "DEMAA_FORCE_LOCAL_DATA=true DEMAA_BUILD_DIST_DIR=.next-build next build",
    "build:vercel": "DEMAA_FORCE_LOCAL_DATA=true next build --webpack",
    "build:stable": "DEMAA_FORCE_LOCAL_DATA=true DEMAA_BUILD_DIST_DIR=.next-build TMPDIR=/private/tmp next build",
    "start": "DEMAA_BUILD_DIST_DIR=.next-build next start",
    "lint": "eslint",
    "validate:data": "node scripts/validate-data.mjs && node scripts/validate-systeme-catalog.mjs && node scripts/validate-sector-taxonomy.mjs && node scripts/validate-seo-routes.mjs && node scripts/validate-sector-editorial-links.mjs && node scripts/validate-build-runtime.mjs && node scripts/audit-business-checklists.mjs --strict",
    "audit:seo-foundations": "npm run validate:data && node scripts/audit-free-tools-coverage.mjs && node scripts/audit-generic-fallbacks.mjs && node scripts/audit-system-tool-quality.mjs && node scripts/audit-internal-linking.mjs && node scripts/audit-system-pages.mjs",
    "audit:seo-foundations:ci": "npm run audit:seo-foundations",
    "audit:free-tools-coverage": "node scripts/audit-free-tools-coverage.mjs",
    "audit:generic-fallbacks": "node scripts/audit-generic-fallbacks.mjs",
    "audit:internal-linking": "node scripts/audit-internal-linking.mjs",
    "audit:system-pages": "node scripts/audit-system-pages.mjs",
    "audit:system-tool-quality": "node scripts/audit-system-tool-quality.mjs",
    "audit:tool-modal-readiness": "node scripts/audit-tool-modal-readiness.mjs",
    "audit:business-checklists": "node scripts/audit-business-checklists.mjs --strict && node scripts/audit-business-checklists-semantic.mjs",
    "audit:business-checklists:ci": "node scripts/audit-business-checklists.mjs --strict && node scripts/audit-business-checklists-semantic.mjs --strict --fail-on-warning",
    "seed:enterprise-annuaire": "node scripts/seed-enterprise-annuaire.mjs",
    "sync:enterprise-annuaire": "node scripts/sync-enterprise-annuaire.mjs",
    "sync:tool-directory": "node scripts/sync-tool-directory.mjs"
  },
  "dependencies": {
    "@stripe/stripe-js": "^9.7.0",
    "@vercel/analytics": "^2.0.1",
    "firebase-admin": "^14.1.0",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.7",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
